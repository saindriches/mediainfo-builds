# Pinned build inputs for mediainfo-builds. Human-readable record; keep in sync with
# .github/workflows/build.yml (the workflow reads these from its own env).
#
# We build MediaInfo (the mediainfo CLI, plus a MediaInfo.app wxWidgets GUI on macOS) from its
# three source repos: ZenLib (base library), MediaInfoLib (the parsing library), and MediaInfo
# (the CLI at Project/GNU/CLI and the wx GUI at Project/GNU/GUI). MediaInfoLib is built straight
# from the MMT/TLV PR branch (saindriches/MediaInfoLib @ mmt-tlv, PR #2647), which carries the
# File_MmtTlv MMT/TLV parser (ARIB STD-B60/B61) in-tree, so mediainfo reports assets, codecs,
# EIT program info, service, audio, and scramble state from Japanese ISDB-S3 4K/8K .mmts files.
# On scrambled streams the clear signaling still yields the metadata. (Previously this feature was
# carried as patches/mediainfolib/*.patch on top of upstream master; the PR branch supersedes them.)

ZENLIB_REF=v0.4.41                                          # MediaArea/ZenLib tag (macOS/Linux autotools)
ZENLIB_WIN_REF=2ddc277fe7ecfcbfe45616bb9cd9e23079113ecd     # ZenLib master for the Windows GUI MSVC build: its .vcxproj sets ControlFlowGuard+ehcont to match MediaInfo 26.05 (the v0.4.41 tag doesn't -> LNK2047)
MEDIAINFOLIB_REPO=saindriches/MediaInfoLib                  # MMT/TLV PR fork (PR #2647 head repo)
MEDIAINFOLIB_REF=e62f133dea1e01b5f9e0a09afafa6e684d2bcc77   # mmt-tlv branch head; bump to re-sync with the PR
MEDIAINFO_REF=d327f8fe76208f0b70bc08e4b55dca508991500d      # MediaArea/MediaInfo (26.05); CLI + wx GUI sources
MEDIAINFO_VERSION=26.05                                     # version string stamped into MediaInfo.app
WX_VERSION=3.2.6                                            # wxWidgets built static from source for the macOS (universal) + Linux (GTK3) GUI
WX_WIN_VERSION=3.1.7                                        # wxWidgets for the Windows GUI; matches the wx 3.1 lib names hardcoded in MediaInfo's GUI .vcxproj
MACOS_ARCHS=arm64 x86_64                                    # macOS builds one universal2 binary/app covering both
CACHE_EPOCH=4                                               # bump to force a full ZenLib+MediaInfoLib+wx rebuild (busts the caches)
