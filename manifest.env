# Pinned build inputs for mediainfo-builds. Human-readable record; keep in sync with
# .github/workflows/build.yml (the workflow reads these from its own env).
#
# We build MediaInfo (the mediainfo CLI, plus a MediaInfo.app wxWidgets GUI on macOS) from its
# three official source repos: ZenLib (base library), MediaInfoLib (the parsing library, where our
# patches/mediainfolib/*.patch apply), and MediaInfo (the CLI at Project/GNU/CLI and the wx GUI at
# Project/GNU/GUI). The patches add the File_MmtTlv MMT/TLV parser (ARIB STD-B60/B61), so mediainfo
# reports assets, codecs, EIT program info, service, audio, and scramble state from Japanese
# ISDB-S3 4K/8K .mmts files. On scrambled streams the clear signaling still yields the metadata.

ZENLIB_REF=v0.4.41                                          # MediaArea/ZenLib tag
MEDIAINFOLIB_REF=dd11d7971107e1b554e41ed446387d22cb3198e9   # MediaArea/MediaInfoLib base our patches/ target (upstream master, PR #2647 base)
MEDIAINFO_REF=d327f8fe76208f0b70bc08e4b55dca508991500d      # MediaArea/MediaInfo (26.05); CLI + wx GUI sources
MEDIAINFO_VERSION=26.05                                     # version string stamped into MediaInfo.app
WX_VERSION=3.2.6                                            # wxWidgets built static + universal from source for the macOS GUI
MACOS_ARCHS=arm64 x86_64                                    # macOS builds one universal2 binary/app covering both
CACHE_EPOCH=4                                               # bump to force a full ZenLib+MediaInfoLib+wx rebuild (busts the caches)
