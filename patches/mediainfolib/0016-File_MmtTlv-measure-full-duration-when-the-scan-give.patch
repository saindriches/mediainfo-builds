From c45efbd369767664e3f3c7cb014b91fc24ef12b4 Mon Sep 17 00:00:00 2001
From: Rainbaby <rainbaby@outlook.jp>
Date: Tue, 7 Jul 2026 18:12:28 +0900
Subject: [PATCH] File_MmtTlv: measure full duration when the scan gives up

A scrambled, NULL-padded capture inflates the packet count while its clock
barely advances, so the forward scan can exhaust GIVE_UP_AFTER_PACKETS before
the boundary window settles (Settled gates ScanComplete). The give-up then
finalized with no tail probe, clamping Duration to the window (~75 s) even
though the stream runs for hours.

Route the give-up through the same completion path as ScanComplete/NoEpgDone
so it tail-probes for the true end, and prefer the whole-second NTP span when
the tail PTS cannot refresh (an encrypted tail), instead of the truncated PTS.
The clear NTP clock and MPU timestamps at the tail then yield the real span.

Signed-off-by: Rainbaby <rainbaby@outlook.jp>
---
 Source/MediaInfo/Multiple/File_MmtTlv.cpp | 39 ++++++++++++++---------
 1 file changed, 24 insertions(+), 15 deletions(-)

diff --git a/Source/MediaInfo/Multiple/File_MmtTlv.cpp b/Source/MediaInfo/Multiple/File_MmtTlv.cpp
index 39c92c3..5591641 100644
--- a/Source/MediaInfo/Multiple/File_MmtTlv.cpp
+++ b/Source/MediaInfo/Multiple/File_MmtTlv.cpp
@@ -558,13 +558,19 @@ void File_MmtTlv::Streams_Finish()
         Fill(Stream_General, 0, General_Duration_Start,
              Ztring().Date_From_Seconds_1970(Now_First));
 
-    //Stream span, distinct from the Menu Duration (scheduled event length). Prefer
-    //the MPU-PTS span; fall back to the whole-second clock.
-    float64 span_ms = -1;
-    if (Pts_First_Us >= 0 && Pts_Last_Us > Pts_First_Us)
-        span_ms = (float64)(Pts_Last_Us - Pts_First_Us) / 1000.0; // us -> ms, sub-second
-    else if (Now_First >= 0 && Now_Last > Now_First)
-        span_ms = (float64)(Now_Last - Now_First) * 1000.0;       // s -> ms
+    //Stream span, distinct from the Menu Duration (scheduled event length). Prefer the
+    //MPU-PTS span (sub-second), but when the NTP clock ran materially longer the tail PTS was
+    //never read - a scrambled service capture whose end blocks don't decode, or an early
+    //give-up - so the whole-second clock is the true span, not the truncated PTS.
+    float64 pts_span_ms = (Pts_First_Us >= 0 && Pts_Last_Us > Pts_First_Us)
+                        ? (float64)(Pts_Last_Us - Pts_First_Us) / 1000.0 : -1; // us -> ms
+    float64 ntp_span_ms = (Now_First >= 0 && Now_Last > Now_First)
+                        ? (float64)(Now_Last - Now_First) * 1000.0 : -1;       // s -> ms
+    float64 span_ms;
+    if (pts_span_ms > 0 && (ntp_span_ms < 0 || ntp_span_ms <= pts_span_ms + 2000.0))
+        span_ms = pts_span_ms;
+    else
+        span_ms = ntp_span_ms;
     if (span_ms > 0)
     {
         //Float ms keeps the sub-second precision.
@@ -799,12 +805,19 @@ void File_MmtTlv::Data_Parse()
                   && Media_Done_Utc >= 0 && Now_Utc >= 0
                   && Now_Utc - Media_Done_Utc >= BOUNDARY_WINDOW_SECONDS;
 
-    if (ScanComplete || NoEpgDone)
+    // Forward scan spent its packet budget before the boundary window could settle - a scrambled,
+    // NULL-padded capture whose packet count outruns its timeline (the stuffing inflates the count
+    // while the clock barely advances). Finalize like a completion rather than reading on to EOF.
+    bool GaveUp = (Packets_Since_Accept >= GIVE_UP_AFTER_PACKETS);
+
+    if (ScanComplete || NoEpgDone || GaveUp)
     {
-        // NoEpgDone stopped short of the end, so its tail is always unread; a normal completion
-        // only needs the tail when the forward scan has not reached it yet.
+        // A give-up or NoEpgDone stopped short of the end, so the tail is unread; a normal
+        // completion only needs the tail when the forward scan has not reached it yet. The tail
+        // probe is what fixes the span: it advances the clock (and PTS, when readable) to the true
+        // end, so a give-up no longer clamps Duration to the boundary window.
         bool TailUnread = Now_First >= 0 && File_Size != (int64u)-1 && File_Size > TAIL_PROBE_BYTES
-                       && (NoEpgDone || File_Offset + Buffer_Offset < File_Size - TAIL_PROBE_BYTES);
+                       && ((NoEpgDone || GaveUp) || File_Offset + Buffer_Offset < File_Size - TAIL_PROBE_BYTES);
         if (TailUnread)
         {
             Phase = Phase_Tail;
@@ -814,11 +827,7 @@ void File_MmtTlv::Data_Parse()
             return;
         }
         Finish();
-        return;
     }
-
-    if (Packets_Since_Accept >= GIVE_UP_AFTER_PACKETS)
-        Finish();
 }
 
