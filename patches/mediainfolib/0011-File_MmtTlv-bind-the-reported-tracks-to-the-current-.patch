From 014d7018c875d0ef764de88cb24f0385c706f4ef Mon Sep 17 00:00:00 2001
From: Rainbaby <rainbaby@outlook.jp>
Date: Mon, 6 Jul 2026 02:08:33 +0900
Subject: [PATCH 11/14] File_MmtTlv: bind the reported tracks to the current
 MPT version

The MPT version identifies the package; a change means the track set
changed, so replace it instead of keeping the fullest ever. A program
with fewer tracks then drops the vanished ones rather than leaving ghosts.

Signed-off-by: Rainbaby <rainbaby@outlook.jp>
---
 Source/MediaInfo/Multiple/File_MmtTlv.cpp | 19 +++++++++++++++++--
 Source/MediaInfo/Multiple/File_MmtTlv.h   |  3 ++-
 2 files changed, 19 insertions(+), 3 deletions(-)

diff --git a/Source/MediaInfo/Multiple/File_MmtTlv.cpp b/Source/MediaInfo/Multiple/File_MmtTlv.cpp
index 87f5193..6dd552e 100644
--- a/Source/MediaInfo/Multiple/File_MmtTlv.cpp
+++ b/Source/MediaInfo/Multiple/File_MmtTlv.cpp
@@ -262,6 +262,7 @@ File_MmtTlv::File_MmtTlv()
     Eit_ServiceId_Found      = false;
     Mpt_Found                = false;
     Mpt_AssetCount           = -1;
+    Mpt_Version              = -1;
     Eit_Start_Utc            = -1;
     for (int i = 0; i < 8; ++i) TransferSeen[i] = 0;
     Sdt_Found                = false;
@@ -1369,13 +1370,27 @@ void File_MmtTlv::Parse_Mpt(const int8u* Data, size_t Size)
         Found.push_back(a);
     }
 
-    //Commit the fullest MPT, not the first: the asset list settles after a program switch.
+    //The MPT version identifies the current package. A change replaces the track set (dropping
+    //what the new program no longer carries); within a version keep the fullest, as the asset
+    //list builds up after a tune-in. The tail probe is a different program near EOF, so skip it.
     int Media = 0;
     for (size_t i = 0; i < Found.size(); ++i)
         if (Found[i].Type == ASSET_HEV1 || Found[i].Type == ASSET_MP4A || Found[i].Type == ASSET_STPP)
             ++Media;
-    if (Media && Media >= Mpt_AssetCount)
+    bool NewVersion = ((int)Data[1] != Mpt_Version);
+    if (Phase == Phase_Scan && Media && (NewVersion || Media > Mpt_AssetCount))
     {
+        if (NewVersion)
+        {
+            //Drop the previous package's parsers; its packet_ids and count may differ.
+            for (std::map<int16u, media_parser>::iterator It = MediaParsers.begin();
+                 It != MediaParsers.end(); ++It)
+                delete It->second.Parser;
+            MediaParsers.clear();
+            Mpt_Version      = Data[1];
+            Media_Probe_Done = false;
+            Core_Done_At     = (int64u)-1;
+        }
         Mpt_AssetCount = Media;
         Assets    = Found;
         Mpt_Found = true;
diff --git a/Source/MediaInfo/Multiple/File_MmtTlv.h b/Source/MediaInfo/Multiple/File_MmtTlv.h
index e0f90ee..59b3d99 100644
--- a/Source/MediaInfo/Multiple/File_MmtTlv.h
+++ b/Source/MediaInfo/Multiple/File_MmtTlv.h
@@ -164,7 +164,8 @@ private :
     Ztring   Eit_Language;
 
     bool     Mpt_Found;
-    int      Mpt_AssetCount;     //media assets in the committed MPT; a shorter later one is ignored
+    int      Mpt_AssetCount;     //media assets in the committed MPT version (fullest within it)
+    int      Mpt_Version;        //committed MPT version; a change replaces the track set
     int      TransferSeen[8];    //video transfer histogram (STD-B60 7-51); the majority wins
 
     //Per-channel, so it survives an EIT boundary re-scan (unlike the MPT).
-- 
