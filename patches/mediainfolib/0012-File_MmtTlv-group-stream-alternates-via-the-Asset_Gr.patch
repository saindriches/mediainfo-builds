From ac13dc0124187896fa16c999aad2a17a5f091508 Mon Sep 17 00:00:00 2001
From: Rainbaby <rainbaby@outlook.jp>
Date: Mon, 6 Jul 2026 02:32:14 +0900
Subject: [PATCH 12/14] File_MmtTlv: group stream alternates via the
 Asset_Group_Descriptor

The Asset_Group_Descriptor (STD-B60 7.4.3.1) groups the main and robust
backup versions of a stream under one group_identification (rain fade),
selection_level 0 the default. Expose group_identification as the
AlternateGroup and Default the level-0 member; absent it, Default falls
back to the main_component flag.

Signed-off-by: Rainbaby <rainbaby@outlook.jp>
---
 Source/MediaInfo/Multiple/File_MmtTlv.cpp | 25 +++++++++++++++++++++--
 Source/MediaInfo/Multiple/File_MmtTlv.h   |  6 +++++-
 2 files changed, 28 insertions(+), 3 deletions(-)

diff --git a/Source/MediaInfo/Multiple/File_MmtTlv.cpp b/Source/MediaInfo/Multiple/File_MmtTlv.cpp
index 6dd552e..88f3711 100644
--- a/Source/MediaInfo/Multiple/File_MmtTlv.cpp
+++ b/Source/MediaInfo/Multiple/File_MmtTlv.cpp
@@ -321,6 +321,10 @@ void File_MmtTlv::Streams_Fill()
     Fill(Stream_General, 0, General_Format_Info, "MMT protocol over TLV packets (ARIB STD-B32)");
 
     //A/V/subtitle streams from the MPT asset list.
+    //The Asset_Group_Descriptor (STD-B60 7.4.3.1) groups the main and robust-backup versions of a
+    //stream under one group_identification (rain fade); selection_level 0 is the default. Expose
+    //the group as the AlternateGroup and Default the level-0 member. Absent it GroupId is -1, so
+    //Default falls back to the main_component flag alone.
     for (size_t i = 0; i < Assets.size(); ++i)
     {
         const asset& A = Assets[i];
@@ -334,6 +338,12 @@ void File_MmtTlv::Streams_Fill()
                     Fill(Stream_Video, StreamPos_Last, Video_ID, A.PacketId, 10);
                 if (PidEncrypted(A.PacketId))
                     Fill(Stream_Video, StreamPos_Last, "Encryption", "Encrypted");
+                if (A.GroupId >= 0)
+                {
+                    Fill(Stream_Video, StreamPos_Last, Video_AlternateGroup, A.GroupId);
+                    if (A.SelectionLevel == 0)
+                        Fill(Stream_Video, StreamPos_Last, Video_Default, "Yes");
+                }
                 {
                     std::map<int16u, media_parser>::iterator It = MediaParsers.find(A.PacketId);
                     if (It != MediaParsers.end())
@@ -365,7 +375,9 @@ void File_MmtTlv::Streams_Fill()
                     Fill(Stream_Audio, StreamPos_Last, Audio_Language, A.Language);
                 if (!A.Title.empty())
                     Fill(Stream_Audio, StreamPos_Last, Audio_Title, A.Title);
-                if (A.MainComponent)
+                if (A.GroupId >= 0)
+                    Fill(Stream_Audio, StreamPos_Last, Audio_AlternateGroup, A.GroupId);
+                if (A.MainComponent && A.SelectionLevel == 0)
                     Fill(Stream_Audio, StreamPos_Last, Audio_Default, "Yes");
                 //audio_for_handicapped 0b01 = 音声解説. Only the VI case maps cleanly.
                 if (A.Handicapped == 0x01)
@@ -1299,6 +1311,8 @@ void File_MmtTlv::Parse_Mpt(const int8u* Data, size_t Size)
         int8u  vid_aspect    = 0;
         int8u  vid_scan      = 0xFF;
         int8u  vid_framerate = 0;
+        int    grp_id        = -1;
+        int8u  sel_level     = 0;
         {
             const int8u* d = p; size_t dn = asset_desc_len;
             while (dn >= 3)
@@ -1307,7 +1321,12 @@ void File_MmtTlv::Parse_Mpt(const int8u* Data, size_t Size)
                 int8u  dlen = d[2]; // 8-bit length for these MMT descriptor tags
                 if ((size_t)3 + dlen > dn) break;
                 const int8u* db = d + 3;
-                if (dtag == 0x8020) // MH_DATA_COMPONENT_DESCRIPTOR
+                if (dtag == 0x8000 && dlen >= 2 && grp_id < 0) // ASSET_GROUP_DESCRIPTOR
+                {
+                    grp_id    = db[0]; // group_identification
+                    sel_level = db[1]; // selection_level (0 = default)
+                }
+                else if (dtag == 0x8020) // MH_DATA_COMPONENT_DESCRIPTOR
                 {
                     // data_component_id 0x0020 = 2nd-gen closed caption; then
                     // Additional_Arib_Subtitle_Info type (top 2 bits of body[5])
@@ -1367,6 +1386,8 @@ void File_MmtTlv::Parse_Mpt(const int8u* Data, size_t Size)
         a.VideoAspect     = vid_aspect;
         a.VideoScan       = vid_scan;
         a.VideoFrameRate  = vid_framerate;
+        a.GroupId         = grp_id;
+        a.SelectionLevel  = sel_level;
         Found.push_back(a);
     }
 
diff --git a/Source/MediaInfo/Multiple/File_MmtTlv.h b/Source/MediaInfo/Multiple/File_MmtTlv.h
index 59b3d99..6eda27a 100644
--- a/Source/MediaInfo/Multiple/File_MmtTlv.h
+++ b/Source/MediaInfo/Multiple/File_MmtTlv.h
@@ -110,10 +110,14 @@ private :
         int8u  VideoAspect;
         int8u  VideoScan;       //0=interlaced, 1=progressive, 0xFF=none
         int8u  VideoFrameRate;
+        //Asset_Group_Descriptor (0x8000): main+backup of a stream share GroupId; level 0 = default.
+        int    GroupId;
+        int8u  SelectionLevel;
         asset() : Type(0), PacketId(0), Superimpose(false),
                   MainComponent(false), Handicapped(0),
                   AudioMode(0), SamplingCode(0),
-                  VideoResolution(0), VideoAspect(0), VideoScan(0xFF), VideoFrameRate(0) {}
+                  VideoResolution(0), VideoAspect(0), VideoScan(0xFF), VideoFrameRate(0),
+                  GroupId(-1), SelectionLevel(0) {}
     };
     std::vector<asset> Assets;
 
-- 
