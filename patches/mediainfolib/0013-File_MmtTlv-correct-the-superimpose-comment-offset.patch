From 6de45214e00ab40bf66ca7e4d933cd78caf112e8 Mon Sep 17 00:00:00 2001
From: Rainbaby <rainbaby@outlook.jp>
Date: Mon, 6 Jul 2026 03:13:37 +0900
Subject: [PATCH 13/14] File_MmtTlv: correct the superimpose comment offset

The type field is at db[7] (after the 3-byte language code), not body[5];
the code was right, the comment wrong. STD-B60 Table 9-4.

Signed-off-by: Rainbaby <rainbaby@outlook.jp>
---
 Source/MediaInfo/Multiple/File_MmtTlv.cpp | 6 +++---
 1 file changed, 3 insertions(+), 3 deletions(-)

diff --git a/Source/MediaInfo/Multiple/File_MmtTlv.cpp b/Source/MediaInfo/Multiple/File_MmtTlv.cpp
index 88f3711..04a7874 100644
--- a/Source/MediaInfo/Multiple/File_MmtTlv.cpp
+++ b/Source/MediaInfo/Multiple/File_MmtTlv.cpp
@@ -1328,9 +1328,9 @@ void File_MmtTlv::Parse_Mpt(const int8u* Data, size_t Size)
                 }
                 else if (dtag == 0x8020) // MH_DATA_COMPONENT_DESCRIPTOR
                 {
-                    // data_component_id 0x0020 = 2nd-gen closed caption; then
-                    // Additional_Arib_Subtitle_Info type (top 2 bits of body[5])
-                    // == 0b01 is superimpose (ARIB STD-B60).
+                    // data_component_id 0x0020 = caption; Additional_Arib_Subtitle_Info type
+                    // (db[7] bits 7-6, after the 3-byte language code, STD-B60 Table 9-4):
+                    // 01 = superimpose, 00 = subtitle.
                     if (dlen >= 8 && RB16(db) == 0x0020)
                         superimpose = ((db[7] >> 6) & 0x03) == 0x01;
                 }                else if (dtag == 0x8014) // MH_AUDIO_COMPONENT_DESCRIPTOR
