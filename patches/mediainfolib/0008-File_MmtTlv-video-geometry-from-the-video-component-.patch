From 560fa2353905f80fdcbee48964ece62986ecbe9b Mon Sep 17 00:00:00 2001
From: Rainbaby <rainbaby@outlook.jp>
Date: Mon, 6 Jul 2026 01:08:06 +0900
Subject: [PATCH 08/14] File_MmtTlv: video geometry from the video-component
 descriptor

Fill Width/Height, frame rate and scan from 0x8010 (in the clear) where
the ES cannot; transfer and colour reuse the shared Mpegv_* strings.

Signed-off-by: Rainbaby <rainbaby@outlook.jp>
---
 Source/MediaInfo/Multiple/File_MmtTlv.cpp | 92 +++++++++++++++++++++--
 Source/MediaInfo/Multiple/File_MmtTlv.h   | 15 +++-
 2 files changed, 98 insertions(+), 9 deletions(-)

diff --git a/Source/MediaInfo/Multiple/File_MmtTlv.cpp b/Source/MediaInfo/Multiple/File_MmtTlv.cpp
index a5023d0..f23daae 100644
--- a/Source/MediaInfo/Multiple/File_MmtTlv.cpp
+++ b/Source/MediaInfo/Multiple/File_MmtTlv.cpp
@@ -45,6 +45,11 @@
 namespace MediaInfoLib
 {
 
+// Shared VUI strings (File_Mpegv.cpp) so descriptor and ES paths agree.
+extern const char* Mpegv_colour_primaries(int8u colour_primaries);
+extern const char* Mpegv_transfer_characteristics(int8u transfer_characteristics);
+extern const char* Mpegv_matrix_coefficients(int8u matrix_coefficients);
+
 //***************************************************************************
 // Constants
 //***************************************************************************
@@ -159,6 +164,30 @@ namespace
 
     inline int bcd2(int8u b) { return (b >> 4) * 10 + (b & 0x0F); }
 
+    // MH-video-component geometry (STD-B60).
+    inline int VideoResolutionHeight(int8u code)
+    {
+        switch (code)
+        {
+            case 1: return 180;  case 2: return 240;  case 3: return 480;
+            case 4: return 720;  case 5: return 1080; case 6: return 2160; case 7: return 4320;
+            default: return 0;
+        }
+    }
+    inline float64 VideoFrameRateFps(int8u code)
+    {
+        switch (code)
+        {
+            case 1: return 15;               case 2: return 24000.0 / 1001;
+            case 3: return 24;               case 4: return 25;
+            case 5: return 30000.0 / 1001;   case 6: return 30;
+            case 7: return 50;               case 8: return 60000.0 / 1001;
+            case 9: return 60;               case 10: return 100;
+            case 11: return 120000.0 / 1001; case 12: return 120;
+            default: return 0;
+        }
+    }
+
     // MH-audio-component sampling_rate 3-bit code -> Hz. 0/4 reserved.
     inline int32u AudioSamplingRate(int8u code)
     {
@@ -299,7 +328,21 @@ void File_MmtTlv::Streams_Fill()
                 {
                     std::map<int16u, media_parser>::iterator It = MediaParsers.find(A.PacketId);
                     if (It != MediaParsers.end())
+                    {
                         It->second.StreamPos = StreamPos_Last;
+                        //Seed geometry from the descriptor; the ES overrides it at finish.
+                        int h = VideoResolutionHeight(A.VideoResolution);
+                        if (h)
+                        {
+                            It->second.DescHeight = h;
+                            if (A.VideoAspect == 1)
+                                It->second.DescWidth = h * 4 / 3;
+                            else if (A.VideoAspect == 2 || A.VideoAspect == 3)
+                                It->second.DescWidth = h * 16 / 9;
+                        }
+                        It->second.DescFrameRate = VideoFrameRateFps(A.VideoFrameRate);
+                        It->second.DescScan      = A.VideoScan;
+                    }
                 }
                 break;
             case ASSET_MP4A:
@@ -424,15 +467,35 @@ void File_MmtTlv::Streams_Finish()
                     Fill(Stream_Audio, M.StreamPos, Audio_ChannelLayout, Ztring().From_UTF8(M.DescLayout), true);
             }
         }
-        //Trust the descriptor's majority transfer over the HEVC VUI, which can disagree (an SDR
-        //program carried on an HLG channel signals HLG in the VUI but BT.2020 in the descriptor).
+        //From 0x8010: transfer overrides the HEVC VUI; geometry and colour fill the ES's gaps.
         if (M.StreamKind == Stream_Video)
         {
             int dom = 1;
             for (int t = 2; t < 8; ++t) if (TransferSeen[t] > TransferSeen[dom]) dom = t;
-            const char* tc = TransferSeen[dom] ? (dom == 5 ? "HLG" : dom == 4 ? "PQ" : dom == 3 ? "BT.2020 (10-bit)" : dom == 1 ? "BT.709" : NULL) : NULL;
-            if (tc)
-                Fill(Stream_Video, M.StreamPos, Video_transfer_characteristics, tc, Unlimited, true, true);
+            if (TransferSeen[dom])
+            {
+                //Descriptor -> VUI code (STD-B60 Table 7-51).
+                int8u vui = dom == 5 ? 18 : dom == 4 ? 16 : dom == 3 ? 14 : dom == 2 ? 11 : 1;
+                Fill(Stream_Video, M.StreamPos, Video_transfer_characteristics, Mpegv_transfer_characteristics(vui), Unlimited, true, true);
+                if (dom == 3 || dom == 4 || dom == 5)
+                {
+                    if (Retrieve_Const(Stream_Video, M.StreamPos, Video_colour_primaries).empty())
+                        Fill(Stream_Video, M.StreamPos, Video_colour_primaries, Mpegv_colour_primaries(9));
+                    if (Retrieve_Const(Stream_Video, M.StreamPos, Video_matrix_coefficients).empty())
+                        Fill(Stream_Video, M.StreamPos, Video_matrix_coefficients, Mpegv_matrix_coefficients(9));
+                }
+            }
+            //Prefer the ES; fill only the gaps it left.
+            if (M.DescHeight && Retrieve_Const(Stream_Video, M.StreamPos, Video_Height).empty())
+            {
+                Fill(Stream_Video, M.StreamPos, Video_Height, M.DescHeight);
+                if (M.DescWidth)
+                    Fill(Stream_Video, M.StreamPos, Video_Width, M.DescWidth);
+            }
+            if (M.DescFrameRate > 0 && Retrieve_Const(Stream_Video, M.StreamPos, Video_FrameRate).empty())
+                Fill(Stream_Video, M.StreamPos, Video_FrameRate, M.DescFrameRate, 3);
+            if (M.DescScan != 0xFF && Retrieve_Const(Stream_Video, M.StreamPos, Video_ScanType).empty())
+                Fill(Stream_Video, M.StreamPos, Video_ScanType, M.DescScan ? "Progressive" : "Interlaced");
         }
         delete M.Parser;
         M.Parser = NULL;
@@ -1208,6 +1271,10 @@ void File_MmtTlv::Parse_Mpt(const int8u* Data, size_t Size)
         int8u  aud_handicap  = 0;
         int8u  aud_mode      = 0;
         int8u  aud_samp      = 0;
+        int8u  vid_resolution= 0;
+        int8u  vid_aspect    = 0;
+        int8u  vid_scan      = 0xFF;
+        int8u  vid_framerate = 0;
         {
             const int8u* d = p; size_t dn = asset_desc_len;
             while (dn >= 3)
@@ -1245,10 +1312,17 @@ void File_MmtTlv::Parse_Mpt(const int8u* Data, size_t Size)
                 }
                 else if (dtag == 0x8010) // MH_VIDEO_COMPONENT_DESCRIPTOR
                 {
-                    //b4 hi nibble = transfer characteristics (STD-B60 Table 7-51). Count into a
-                    //histogram so a few stray MPTs cannot flip an SDR program to HDR.
+                    //Transfer (b4 hi nibble); histogram so stray MPTs can't flip SDR to HDR.
                     if (dlen >= 5 && (db[4] >> 4) < 8)
                         TransferSeen[db[4] >> 4]++;
+                    //b0 resolution|aspect, b1 scan|frame_rate (STD-B60 Table 7-47).
+                    if (dlen >= 2)
+                    {
+                        vid_resolution = db[0] >> 4;
+                        vid_aspect     = db[0] & 0x0F;
+                        vid_scan       = db[1] >> 7;
+                        vid_framerate  = db[1] & 0x1F;
+                    }
                 }
                 d += 3 + dlen; dn -= 3 + dlen;
             }
@@ -1265,6 +1339,10 @@ void File_MmtTlv::Parse_Mpt(const int8u* Data, size_t Size)
         a.Handicapped   = aud_handicap;
         a.AudioMode     = aud_mode;
         a.SamplingCode  = aud_samp;
+        a.VideoResolution = vid_resolution;
+        a.VideoAspect     = vid_aspect;
+        a.VideoScan       = vid_scan;
+        a.VideoFrameRate  = vid_framerate;
         Found.push_back(a);
     }
 
diff --git a/Source/MediaInfo/Multiple/File_MmtTlv.h b/Source/MediaInfo/Multiple/File_MmtTlv.h
index 4a4df69..ff4896d 100644
--- a/Source/MediaInfo/Multiple/File_MmtTlv.h
+++ b/Source/MediaInfo/Multiple/File_MmtTlv.h
@@ -105,9 +105,15 @@ private :
         int8u  Handicapped;   //audio_for_handicapped: 0b01 = VI commentary
         int8u  AudioMode;     //component_type & 0x1F (0=none)
         int8u  SamplingCode;  //sampling_rate 3-bit code (0=none)
+        //MH-video-component descriptor (0x8010):
+        int8u  VideoResolution; //0=none, 6=2160, 7=4320
+        int8u  VideoAspect;
+        int8u  VideoScan;       //0=interlaced, 1=progressive, 0xFF=none
+        int8u  VideoFrameRate;
         asset() : Type(0), PacketId(0), Superimpose(false),
                   MainComponent(false), Handicapped(0),
-                  AudioMode(0), SamplingCode(0) {}
+                  AudioMode(0), SamplingCode(0),
+                  VideoResolution(0), VideoAspect(0), VideoScan(0xFF), VideoFrameRate(0) {}
     };
     std::vector<asset> Assets;
 
@@ -124,9 +130,14 @@ private :
         int64u         MpuSeen;     //MPU packets routed here (scramble give-up)
         int            DescCh;      //audio-component channel count
         const char*    DescLayout;  //layout for DescCh (static; may be NULL)
+        //Video geometry from 0x8010; fills the ES's gaps at finish.
+        int            DescWidth, DescHeight;
+        float64        DescFrameRate;
+        int8u          DescScan;              //0xFF=none
         media_parser() : Parser(NULL), StreamKind(Stream_Video), StreamPos(0),
                          IsAac(false), Done(false), Fed(0), MpuSeen(0),
-                         DescCh(0), DescLayout(NULL) {}
+                         DescCh(0), DescLayout(NULL),
+                         DescWidth(0), DescHeight(0), DescFrameRate(0), DescScan(0xFF) {}
     };
     std::map<int16u, media_parser> MediaParsers;
     bool     Media_Probe_Done;
-- 
